# ──────────────────────────────────────────────────────────────
# Decise – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
# ──────────────────────────────────────────────────────────────

# Node environment: development | staging | production
NODE_ENV=development

# ── Database (PostgreSQL via Prisma) ──────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://user:password@localhost:5432/desice?schema=public

# ── AWS (S3 file uploads) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
AWS_S3_BUCKET=desicefilesupload

# ── JWT / Auth ────────────────────────────────────────────────
JWT_TOKEN_KEY=change-me-to-a-long-random-string
COOKIE_PRIVATE_KEY=change-me-to-another-long-random-string

# ── Encryption (AES-256-CBC) ──────────────────────────────────
# Must be exactly 32 characters
ENCRYPTION_KEY=change-me-to-a-32-char-secret!!

# ── Email / SMTP ──────────────────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_ID=noreply@example.com
MAIL_PASSWORD=

# ── Akahu (NZ Open Banking) ───────────────────────────────────
AKAHU_APP_TOKEN=app_token_xxxxxxxxxxxxxxxxxxxx
AKAHU_APP_SECRET=

# ── Firebase (push notifications) ────────────────────────────
# Paste the contents of your serviceAccountKey.json as a single-line
# JSON string (use JSON.stringify or a base64-encoded value)
FIREBASE_SERVICE_ACCOUNT_JSON=
