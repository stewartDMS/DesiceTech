{
  "version": 2,
  "buildCommand": "npm install --legacy-peer-deps && npx prisma generate",
  "installCommand": "npm install --legacy-peer-deps",
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.js" }
  ]
}
