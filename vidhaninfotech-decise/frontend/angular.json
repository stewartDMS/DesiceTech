{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "decise_development": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/decise_development",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": "src/polyfills.ts",
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "src/favicon.ico",
              "src/assets"
            ],
            "styles": [
              "src/styles.scss",
              "src/assets/css/owl.carousel.min.css",
              "src/assets/css/fontawesome-all.css",
              "src/assets/css/cryptocoins.css",
              "src/assets/css/tabler-icons.css",
              "src/assets/css/styles.css",
              "node_modules/ngx-spinner/animations/ball-atom.css"
            ],
            "scripts": [
              "src/assets/js/jquery.min.js",
              "src/assets/js/app.min.js",
              "src/assets/js/app.init.js",
              "src/assets/js/bootstrap.bundle.min.js",
              "src/assets/js/simplebar.min.js",
              "src/assets/js/sidebarmenu.js",
              "src/assets/js/theme.js",
              "src/assets/js/owl.carousel.min.js",
              "src/assets/js/dashboard.js",
              "node_modules/apexcharts/dist/apexcharts.min.js",
              "node_modules/owl.carousel/dist/owl.carousel.min.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "20mb",
                  "maximumError": "25mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "20mb",
                  "maximumError": "25mb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "browserTarget": "decise_development:build:production"
            },
            "development": {
              "browserTarget": "decise_development:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "decise_development:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "src/test.ts",
            "polyfills": "src/polyfills.ts",
            "tsConfig": "tsconfig.spec.json",
            "karmaConfig": "karma.conf.js",
            "inlineStyleLanguage": "scss",
            "assets": [
              "src/favicon.ico",
              "src/assets"
            ],
            "styles": [
              "src/styles.scss",
              "src/assets/css/owl.carousel.min.css",
              "src/assets/css/fontawesome-all.css",
              "src/assets/css/cryptocoins.css",
              "src/assets/css/tabler-icons.css",
              "src/assets/css/styles.css",
              "node_modules/ngx-spinner/animations/ball-atom.css"
            ],
            "scripts": [
              "src/assets/js/jquery.min.js",
              "src/assets/js/app.min.js",
              "src/assets/js/app.init.js",
              "src/assets/js/bootstrap.bundle.min.js",
              "src/assets/js/simplebar.min.js",
              "src/assets/js/sidebarmenu.js",
              "src/assets/js/theme.js",
              "src/assets/js/owl.carousel.min.js",
              "src/assets/js/dashboard.js",
              "node_modules/apexcharts/dist/apexcharts.min.js",
              "node_modules/owl.carousel/dist/owl.carousel.min.js"
            ]
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "56ce4044-0152-4e2b-b9d6-dd9e434cc9b4"
  }
}